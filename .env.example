# 复制为 .env 或直接在环境中导出
# 本机常用 root；若用仓库内 docker-compose，请改为 screener:screener（见 docker-compose.yml）
DATABASE_URL=mysql+pymysql://root:root@127.0.0.1:3306/value_screener
REDIS_URL=redis://127.0.0.1:6379/0
CACHE_TTL_SECONDS=120
# 设为 1 时开放 POST /api/v1/reference/sync-stock-basic（默认关闭）
# REFERENCE_SYNC_API_ENABLED=1
TUSHARE_TOKEN=
# 全市场股息率接口 GET /api/v1/market/ashare-dividend-yields 对单日 raw 数据的进程内缓存秒数，0 表示不缓存
# VALUE_SCREENER_MARKET_DIVIDEND_CACHE_TTL_SECONDS=120
VALUE_SCREENER_PRIMARY=tushare
# 若 AkShare 必须走系统代理再设为 1（默认不设，避免坏代理连不上东财）
# VALUE_SCREENER_AKSHARE_USE_SYSTEM_PROXY=1

# 可选：评分阈值（缺省使用代码内默认）
# VALUE_SCREENER_GRAHAM_MCAP_NCAV_FULL=0.67
# VALUE_SCREENER_BUFFETT_ROE_EXCELLENT=0.20

# 详情页 AI 分析（LangChain + 兼容 OpenAI 的端点，如字节火山方舟）；需 pip install -e ".[ai]"
# VALUE_SCREENER_AI_ENABLED=1
# VALUE_SCREENER_AI_API_KEY=
# 方舟示例（以控制台为准）：https://ark.cn-beijing.volces.com/api/v3
# VALUE_SCREENER_AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# VALUE_SCREENER_AI_MODEL=ep-xxxxxxxx
# VALUE_SCREENER_AI_CACHE_TTL_SECONDS=3600
# VALUE_SCREENER_AI_TIMEOUT_SECONDS=120

# 公司详情简化 DCF（默认关闭；开启后可通过 include_dcf=1 拉 daily_basic 总股本并计算）
# VALUE_SCREENER_DCF_ENABLED=1
# VALUE_SCREENER_DCF_WACC=0.09
# VALUE_SCREENER_DCF_STAGE1_GROWTH=0.02
# VALUE_SCREENER_DCF_TERMINAL_GROWTH=0.025
# VALUE_SCREENER_DCF_FORECAST_YEARS=5
# VALUE_SCREENER_DCF_WACC_TERMINAL_EPSILON=0.0005
# VALUE_SCREENER_DCF_TTM_PERIODS=4
# include_dcf=1 时若库内缺投资现金流等字段，将按需调用 TuShare 同步现金流量表与资产负债表并落库
# VALUE_SCREENER_DCF_SYNC_SINCE_YEARS=5
# 超过该天数未更新年报则基期优先改用四季度单季还原 TTM（仍无足够季报时退回陈旧年报）
# VALUE_SCREENER_DCF_ANNUAL_STALE_DAYS=550
# VALUE_SCREENER_DCF_WACC_MIN=0.04
# VALUE_SCREENER_DCF_WACC_MAX=0.25
# VALUE_SCREENER_DCF_STAGE1_G_MIN=-0.05
# VALUE_SCREENER_DCF_STAGE1_G_MAX=0.20
# VALUE_SCREENER_DCF_TERMINAL_G_MIN=-0.02
# VALUE_SCREENER_DCF_TERMINAL_G_MAX=0.06
# VALUE_SCREENER_DCF_DAILY_BASIC_TIMEOUT_SECONDS=12
# 金融业用年报归母净利作折现基数时先乘该系数（0.15～1，默认 0.35），粗代理派息与资本留存
# VALUE_SCREENER_DCF_FINANCIAL_NI_BASE_SCALE=0.35
